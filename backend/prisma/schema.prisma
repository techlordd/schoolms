// prisma/schema.prisma
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  admin
  head_teacher
  teacher
  class_teacher
  student
  parent
}

enum AttendanceStatus {
  present
  absent
  late
}

enum PaymentMethod {
  cash
  transfer
  card
  cheque
}

enum PayrollStatus {
  pending
  paid
}

enum EventType {
  exam
  holiday
  meeting
  activity
  sports
  other
}

enum AssignmentType {
  homework
  classwork
  project
  test
}

enum DocumentCategory {
  academic
  admin
  medical
  legal
  financial
  other
}

enum RelatedType {
  student
  staff
  school
}

// ─── Core Tables ──────────────────────────────────────────────────────────────

model School {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(150)
  code         String   @unique @db.VarChar(20)
  address      String?
  phone        String?  @db.VarChar(20)
  email        String?  @db.VarChar(100)
  logoUrl      String?
  currentTerm  Int      @default(1)
  currentYear  String   @default("2024/2025") @db.VarChar(10)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users            User[]
  classes          Class[]
  subjects         Subject[]
  students         Student[]
  attendance       Attendance[]
  assignments      Assignment[]
  results          Result[]
  feeStructures    FeeStructure[]
  feePayments      FeePayment[]
  expenses         Expense[]
  announcements    Announcement[]
  calendarEvents   CalendarEvent[]
  documents        Document[]
  staffMeetings    StaffMeeting[]
  messages         Message[]

  @@map("schools")
}

model User {
  id           String   @id @default(uuid())
  schoolId     String
  email        String   @unique @db.VarChar(150)
  passwordHash String
  role         Role
  firstName    String   @db.VarChar(80)
  lastName     String   @db.VarChar(80)
  phone        String?  @db.VarChar(20)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school           School         @relation(fields: [schoolId], references: [id])
  studentProfile   Student?       @relation("StudentUser")
  staffProfile     StaffProfile?
  classTeacher     Class[]        @relation("ClassTeacher")
  classSubjects    ClassSubject[]
  markedAttendance Attendance[]   @relation("MarkedBy")
  createdAssignments Assignment[] @relation("AssignmentCreator")
  gradedSubmissions AssignmentSubmission[] @relation("GradedBy")
  enteredResults   Result[]       @relation("ResultTeacher")
  reportedPayments FeePayment[]   @relation("PaymentRecorder")
  recordedExpenses Expense[]
  sentMessages     Message[]      @relation("Sender")
  receivedMessages Message[]      @relation("Receiver")
  announcements    Announcement[]
  calendarEvents   CalendarEvent[]
  uploadedDocuments Document[]
  staffMeetingsCreated StaffMeeting[]
  teachingLogs     TeachingLog[]
  parentStudents   ParentStudent[] @relation("ParentUser")

  @@map("users")
}

model Class {
  id             String   @id @default(uuid())
  schoolId       String
  name           String   @db.VarChar(30)
  level          String   @db.VarChar(20)
  classTeacherId String?
  capacity       Int      @default(40)
  academicYear   String   @db.VarChar(10)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school        School         @relation(fields: [schoolId], references: [id])
  classTeacher  User?          @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  students      Student[]
  classSubjects ClassSubject[]
  attendance    Attendance[]
  assignments   Assignment[]
  results       Result[]
  reportCards   ReportCard[]
  teachingLogs  TeachingLog[]

  @@map("classes")
}

model Subject {
  id          String   @id @default(uuid())
  schoolId    String
  name        String   @db.VarChar(80)
  code        String?  @db.VarChar(10)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school       School         @relation(fields: [schoolId], references: [id])
  classSubjects ClassSubject[]
  assignments  Assignment[]
  results      Result[]
  teachingLogs TeachingLog[]

  @@map("subjects")
}

model ClassSubject {
  id             String @id @default(uuid())
  classId        String
  subjectId      String
  teacherId      String?
  periodsPerWeek Int    @default(5)

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher User?   @relation(fields: [teacherId], references: [id])

  @@unique([classId, subjectId])
  @@map("class_subjects")
}

model Student {
  id             String   @id @default(uuid())
  schoolId       String
  userId         String?  @unique
  studentId      String   @unique @db.VarChar(20)
  classId        String
  firstName      String   @db.VarChar(80)
  lastName       String   @db.VarChar(80)
  dateOfBirth    DateTime @db.Date
  gender         String   @db.VarChar(10)
  bloodGroup     String?  @db.VarChar(5)
  allergies      String?
  medicalNotes   String?
  emergencyPhone String?  @db.VarChar(20)
  photoUrl       String?
  enrolledAt     DateTime @default(now()) @db.Date
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school         School         @relation(fields: [schoolId], references: [id])
  user           User?          @relation("StudentUser", fields: [userId], references: [id])
  class          Class          @relation(fields: [classId], references: [id])
  parents        ParentStudent[]
  attendance     Attendance[]
  submissions    AssignmentSubmission[]
  results        Result[]
  reportCards    ReportCard[]
  feePayments    FeePayment[]

  @@map("students")
}

model ParentStudent {
  id           String  @id @default(uuid())
  parentId     String
  studentId    String
  relationship String  @db.VarChar(20)
  isPrimary    Boolean @default(false)

  parent  User    @relation("ParentUser", fields: [parentId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([parentId, studentId])
  @@map("parent_students")
}

// ─── Academic Tables ──────────────────────────────────────────────────────────

model Attendance {
  id           String           @id @default(uuid())
  schoolId     String
  studentId    String
  classId      String
  date         DateTime         @db.Date
  status       AttendanceStatus
  markedById   String?
  note         String?
  term         Int
  academicYear String           @db.VarChar(10)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  school    School  @relation(fields: [schoolId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])
  class     Class   @relation(fields: [classId], references: [id])
  markedBy  User?   @relation("MarkedBy", fields: [markedById], references: [id])

  @@unique([studentId, date])
  @@map("attendance")
}

model Assignment {
  id           String         @id @default(uuid())
  schoolId     String
  classId      String
  subjectId    String
  teacherId    String
  title        String         @db.VarChar(150)
  description  String?
  dueDate      DateTime
  maxScore     Decimal        @default(100) @db.Decimal(5, 2)
  type         AssignmentType @default(homework)
  term         Int
  academicYear String         @db.VarChar(10)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  school      School                 @relation(fields: [schoolId], references: [id])
  class       Class                  @relation(fields: [classId], references: [id])
  subject     Subject                @relation(fields: [subjectId], references: [id])
  teacher     User                   @relation("AssignmentCreator", fields: [teacherId], references: [id])
  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id           String   @id @default(uuid())
  assignmentId String
  studentId    String
  fileUrl      String?
  score        Decimal? @db.Decimal(5, 2)
  feedback     String?
  submittedAt  DateTime?
  gradedAt     DateTime?
  gradedById   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
  gradedBy   User?      @relation("GradedBy", fields: [gradedById], references: [id])

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

model Result {
  id              String   @id @default(uuid())
  schoolId        String
  studentId       String
  classId         String
  subjectId       String
  teacherId       String?
  ca1Score        Decimal? @db.Decimal(5, 2)
  ca2Score        Decimal? @db.Decimal(5, 2)
  examScore       Decimal? @db.Decimal(5, 2)
  totalScore      Decimal? @db.Decimal(5, 2)
  grade           String?  @db.VarChar(3)
  position        Int?
  teacherComment  String?
  term            Int
  academicYear    String   @db.VarChar(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school   School  @relation(fields: [schoolId], references: [id])
  student  Student @relation(fields: [studentId], references: [id])
  class    Class   @relation(fields: [classId], references: [id])
  subject  Subject @relation(fields: [subjectId], references: [id])
  teacher  User?   @relation("ResultTeacher", fields: [teacherId], references: [id])

  @@unique([studentId, subjectId, term, academicYear])
  @@map("results")
}

model ReportCard {
  id                   String   @id @default(uuid())
  studentId            String
  classId              String
  term                 Int
  academicYear         String   @db.VarChar(10)
  totalScore           Decimal? @db.Decimal(6, 2)
  averageScore         Decimal? @db.Decimal(5, 2)
  classPosition        Int?
  classSize            Int?
  headComment          String?
  classTeacherComment  String?
  nextTermBegins       DateTime? @db.Date
  published            Boolean  @default(false)
  pdfUrl               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, term, academicYear])
  @@map("report_cards")
}

model TeachingLog {
  id          String   @id @default(uuid())
  classId     String
  subjectId   String
  teacherId   String
  date        DateTime @db.Date
  topic       String   @db.VarChar(200)
  notes       String?
  resources   String[]
  term        Int
  academicYear String  @db.VarChar(10)
  createdAt   DateTime @default(now())

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher User    @relation(fields: [teacherId], references: [id])

  @@map("teaching_logs")
}

// ─── Finance & HR ─────────────────────────────────────────────────────────────

model FeeStructure {
  id           String   @id @default(uuid())
  schoolId     String
  classLevel   String   @db.VarChar(20)
  amount       Decimal  @db.Decimal(12, 2)
  term         Int
  academicYear String   @db.VarChar(10)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, classLevel, term, academicYear])
  @@map("fee_structures")
}

model FeePayment {
  id            String        @id @default(uuid())
  schoolId      String
  studentId     String
  amountPaid    Decimal       @db.Decimal(12, 2)
  amountDue     Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime      @db.Date
  paymentMethod PaymentMethod @default(cash)
  receiptNumber String        @unique @db.VarChar(30)
  receiptUrl    String?
  recordedById  String?
  term          Int
  academicYear  String        @db.VarChar(10)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  school     School  @relation(fields: [schoolId], references: [id])
  student    Student @relation(fields: [studentId], references: [id])
  recordedBy User?   @relation("PaymentRecorder", fields: [recordedById], references: [id])

  @@map("fee_payments")
}

model StaffProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  schoolId      String
  staffId       String   @unique @db.VarChar(20)
  department    String?  @db.VarChar(80)
  qualification String?
  hireDate      DateTime? @db.Date
  salary        Decimal  @db.Decimal(12, 2)
  bankName      String?  @db.VarChar(80)
  accountNumber String?  @db.VarChar(30)
  nin           String?  @db.VarChar(20)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id])
  payrollRecords PayrollRecord[]

  @@map("staff_profiles")
}

model PayrollRecord {
  id          String        @id @default(uuid())
  staffId     String
  grossSalary Decimal       @db.Decimal(12, 2)
  deductions  Decimal       @default(0) @db.Decimal(12, 2)
  netSalary   Decimal       @db.Decimal(12, 2)
  month       Int
  year        Int
  paidAt      DateTime?
  payslipUrl  String?
  status      PayrollStatus @default(pending)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  staff StaffProfile @relation(fields: [staffId], references: [id])

  @@unique([staffId, month, year])
  @@map("payroll_records")
}

model Expense {
  id          String   @id @default(uuid())
  schoolId    String
  category    String   @db.VarChar(60)
  description String
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime @db.Date
  recordedById String?
  createdAt   DateTime @default(now())

  school     School @relation(fields: [schoolId], references: [id])
  recordedBy User?  @relation(fields: [recordedById], references: [id])

  @@map("expenses")
}

// ─── Communication ────────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(uuid())
  schoolId   String
  senderId   String
  receiverId String
  subject    String?  @db.VarChar(150)
  body       String
  isRead     Boolean  @default(false)
  readAt     DateTime?
  parentId   String?
  createdAt  DateTime @default(now())

  school   School    @relation(fields: [schoolId], references: [id])
  sender   User      @relation("Sender", fields: [senderId], references: [id])
  receiver User      @relation("Receiver", fields: [receiverId], references: [id])
  parent   Message?  @relation("Replies", fields: [parentId], references: [id])
  replies  Message[] @relation("Replies")

  @@map("messages")
}

model Announcement {
  id        String   @id @default(uuid())
  schoolId  String
  authorId  String
  title     String   @db.VarChar(200)
  body      String
  audience  String[]
  pinned    Boolean  @default(false)
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@map("announcements")
}

model CalendarEvent {
  id          String    @id @default(uuid())
  schoolId    String
  createdById String
  title       String    @db.VarChar(200)
  description String?
  eventType   EventType @default(other)
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(true)
  location    String?   @db.VarChar(150)
  audience    String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  school    School @relation(fields: [schoolId], references: [id])
  createdBy User   @relation(fields: [createdById], references: [id])

  @@map("calendar_events")
}

model Document {
  id          String           @id @default(uuid())
  schoolId    String
  uploadedById String
  title       String           @db.VarChar(200)
  category    DocumentCategory @default(other)
  fileUrl     String
  fileSize    BigInt?
  mimeType    String?          @db.VarChar(80)
  relatedType RelatedType?
  relatedId   String?
  createdAt   DateTime         @default(now())

  school     School @relation(fields: [schoolId], references: [id])
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@map("documents")
}

model StaffMeeting {
  id          String   @id @default(uuid())
  schoolId    String
  createdById String
  title       String   @db.VarChar(200)
  date        DateTime
  agenda      String?
  minutes     String?
  attendeeIds String[]
  absentIds   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school    School @relation(fields: [schoolId], references: [id])
  createdBy User   @relation(fields: [createdById], references: [id])

  @@map("staff_meetings")
}
